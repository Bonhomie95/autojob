# ============================================================
#  JOB HUNTER — Environment Configuration
# ============================================================

# --- Groq API Keys ---
# You can use a single key OR multiple keys (recommended).
# With multiple keys the app rotates to the next key automatically
# when one hits its daily/minute token limit.
# Create free accounts at https://console.groq.com (one per email).
#
# Option A: Single key
GROQ_API_KEY=your_groq_api_key_here
#
# Option B: Multiple keys (add as many as you have, any number)
# GROQ_API_KEY_1=gsk_xxxxxxxxxxxxxxxx
# GROQ_API_KEY_2=gsk_yyyyyyyyyyyyyyyy
# GROQ_API_KEY_3=gsk_zzzzzzzzzzzzzzzz
# GROQ_API_KEY_4=
# GROQ_API_KEY_5=
# GROQ_API_KEY_6=
# GROQ_API_KEY_7=
# GROQ_API_KEY_8=
# GROQ_API_KEY_9=
# GROQ_API_KEY_10=
#
# Note: GROQ_API_KEY and GROQ_API_KEY_1..N can coexist — all are loaded and deduplicated.

# Optional: Hunter.io for HR email discovery (25 free/month)
HUNTER_API_KEY=

# --- Target Job Roles (comma-separated) ---
TARGET_ROLES=React Native Developer,Full Stack Engineer,Web3 Engineer,Python Developer,Backend Engineer,Frontend Engineer,Software Developer

# --- Keywords to match in job descriptions (comma-separated) ---
KEYWORDS=React,Node.js,Python,TypeScript,Web3,Solana,Mobile,Remote,React Native,Express

# --- Keywords to SKIP (comma-separated, case-insensitive) ---
BLACKLIST_KEYWORDS=internship,unpaid,commission only,no experience

# --- Salary Preferences ---
MIN_SALARY=40000
MAX_SALARY=300000
SALARY_CURRENCY=USD

# --- Experience Level (comma-separated: junior,mid,senior) ---
EXPERIENCE_LEVEL=mid,senior

# --- Location ---
REMOTE_ONLY=true
TARGET_COUNTRIES=United States,United Kingdom,Canada,Germany,Netherlands,Remote,Worldwide

# --- Candidate Education (used in CV — add as many as needed) ---
# Format: Degree / Certification | Institution | Year(s)
CANDIDATE_EDUCATION_1=BSc, Computer Science | Lagos State University, Lagos, Nigeria | 2018 – 2023
# CANDIDATE_EDUCATION_2=AWS Certified Solutions Architect | Amazon Web Services | 2022
# CANDIDATE_EDUCATION_3=
CANDIDATE_NAME=Adeyemi Joseph
CANDIDATE_EMAIL=bonhomie@bonhomieinc.dev
CANDIDATE_PHONE=+234 903 190 4643
CANDIDATE_LOCATION=Lagos, Nigeria (Open to Remote)
CANDIDATE_LINKEDIN=linkedin.com/in/adeyemi-joseph
CANDIDATE_GITHUB=github.com/Bonhomie95

# Optional: manually list your exact project names (comma-separated).
# Leave blank to let the tool auto-extract from your CV file.
# Use this if auto-extraction ever misses projects or gets names wrong.
# CANDIDATE_PROJECTS=PulseQuiz,bonhomie-react-flow-form,Property Wey International,QuizVideoPython,AI Trader,Mail Deliverability SaaS,Web3 Investment Platform

# --- Proxy / SOCKS (optional — improves scraping reliability) ---
# Set PROXY_ENABLED=true and list your proxies in PROXY_LIST.
# The scraper rotates through them automatically. Failed proxies are
# skipped for the rest of that run. Falls back to direct if all fail.
#
# Supported formats (comma-separated):
#   socks5://user:pass@host:port
#   socks5://host:port
#   socks4://host:port
#   http://user:pass@host:port
#   host:port              (bare host:port is assumed socks5)
#
# Free public SOCKS proxies are unreliable — paid residential or
# datacenter proxies (e.g. Webshare, Oxylabs, Bright Data) work best.
PROXY_ENABLED=false
PROXY_LIST=
# Examples (uncomment and fill in):
# PROXY_LIST=socks5://user:pass@1.2.3.4:1080,socks5://user:pass@5.6.7.8:1080
# PROXY_LIST=socks5://1.2.3.4:1080,socks5://5.6.7.8:1080,socks5://9.10.11.12:1080

# --- Job Sources ---
# Reliable (public JSON APIs — always on):
SCRAPE_LINKEDIN=true
SCRAPE_WEWORKREMOTELY=true
SCRAPE_JOBICY=true
SCRAPE_REMOTIVE=true
SCRAPE_ARBEITNOW=true
# Occasionally rate-limits but works:
SCRAPE_REMOTEOK=true
# RSS feed — less reliable:
SCRAPE_INDEED=true
# Experimental — off by default:
SCRAPE_GOOGLE=false
MAX_JOBS_PER_BOARD=50
# Minimum Groq match score (0–100) to generate documents for a job
MIN_MATCH_SCORE=60
# Generate docs when any contact signal found (URL counts), auto-send still requires real email
# true = always generate (recommended — most jobs use apply URLs not emails)
# false = only generate when HR email, application email, OR apply URL found
GENERATE_DOCS_WITHOUT_HR=true

# --- LinkedIn Auth (optional — improves scraping quality) ---
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# --- Paths ---
OUTPUT_DIR=output
INPUT_DIR=input
DB_PATH=jobhunter.db

# --- Email Sending (SMTP) ---
# Namecheap cPanel webmail — SSL on port 465
SMTP_HOST=bonhomieinc.dev
SMTP_PORT=465
SMTP_USER=bonhomie@bonhomieinc.dev
SMTP_PASSWORD=your_email_password_here
SMTP_FROM=bonhomie@bonhomieinc.dev
# Port 465 uses SSL — STARTTLS not needed
SMTP_TLS=false
# Auto-send during pipeline (true = sends immediately after docs generated)
SMTP_AUTO_SEND=false
# Attachments
SMTP_ATTACH_PDF=true
SMTP_ATTACH_DOCX=false
# Retry failed sends (0 = no retries, 1 = retry once, etc.)
SMTP_RETRY_COUNT=1
FLASK_PORT=5000
FLASK_DEBUG=false
TIMEZONE=Africa/Lagos
