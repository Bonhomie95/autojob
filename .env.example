# ============================================================
#  JOB HUNTER — Environment Configuration
#  Copy this file to .env and fill in your values.
# ============================================================

# ── Groq API (required) ─────────────────────────────────
# Single key:
# GROQ_API_KEY=gsk_...

# Or multiple keys for parallel rate-limit rotation:
GROQ_API_KEY_1=gsk_...
# GROQ_API_KEY_2=gsk_...
# GROQ_API_KEY_3=gsk_...

# ── Optional Integrations ────────────────────────────────
# Hunter.io for HR email discovery (25 lookups/month free)
# HUNTER_API_KEY=

# ── Candidate Info ───────────────────────────────────────
CANDIDATE_NAME=Your Full Name
CANDIDATE_EMAIL=you@example.com
CANDIDATE_PHONE=+1 (000) 000-0000
CANDIDATE_LOCATION=City, Country (Open to Remote)
CANDIDATE_LINKEDIN=https://linkedin.com/in/yourhandle
CANDIDATE_GITHUB=github.com/yourhandle
CANDIDATE_PROJECTS=Project One, Project Two

# ── GitHub Integration ───────────────────────────────────
# Personal access token → AutoJob fetches real repo URLs, descriptions,
# and tech stacks so every generated CV has accurate project bullets & URLs.
#
# Create a token at: https://github.com/settings/tokens
# Required scopes:   read:user  (+ repo if you have private repos to include)
#
# GITHUB_TOKEN=ghp_...
#
# Optional: explicit project → URL overrides (JSON). These take priority over
# auto-fetched GitHub URLs. Use for live demos, private URLs, or non-GitHub repos.
# CANDIDATE_PROJECT_URLS={"WordWar":"https://github.com/you/wordwar","VaultDrop":"https://vaultdrop.io"}

# ── Target Roles (comma-separated) ──────────────────────
TARGET_ROLES=Full Stack Engineer,React Native Developer,Backend Engineer,Software Engineer

# ── Keywords to match (comma-separated) ─────────────────
KEYWORDS=React,Node.js,Python,TypeScript,Remote

# ── Keywords to skip (case-insensitive, comma-separated) ─
BLACKLIST_KEYWORDS=internship,unpaid,commission only

# ── Salary Preferences ───────────────────────────────────
MIN_SALARY=40000
MAX_SALARY=300000
SALARY_CURRENCY=USD

# ── Experience Level ─────────────────────────────────────
EXPERIENCE_LEVEL=mid,senior

# ── Location ─────────────────────────────────────────────
REMOTE_ONLY=true
TARGET_COUNTRIES=United States,United Kingdom,Canada,Germany,Remote,Worldwide

# ── Scrapers ─────────────────────────────────────────────
SCRAPE_LINKEDIN=true
SCRAPE_WEWORKREMOTELY=true
SCRAPE_JOBICY=true
SCRAPE_REMOTIVE=true
SCRAPE_ARBEITNOW=true
SCRAPE_HACKERNEWS=true
SCRAPE_REMOTEOK=true
SCRAPE_INDEED=true
SCRAPE_GOOGLE=false
MAX_JOBS_PER_BOARD=50
MIN_MATCH_SCORE=60

# ── Company Research Enrichment ──────────────────────────
# Uses a Groq call to fetch a company summary before scoring.
# Makes cover letters more personalised. Uses ~1 extra API call per job.
ENRICH_COMPANY_DATA=true

# ── Document Generation ──────────────────────────────────
# false = only generate docs when HR email or apply URL found
# true  = generate docs for every qualified job regardless
GENERATE_DOCS_WITHOUT_HR=false

# ── LinkedIn Auth (optional, improves scraping quality) ──
# LINKEDIN_EMAIL=you@gmail.com
# LINKEDIN_PASSWORD=yourpassword

# ── Paths ─────────────────────────────────────────────────
OUTPUT_DIR=output
INPUT_DIR=input
DB_PATH=jobhunter.db

# ── SMTP (Email Sending) ──────────────────────────────────
# Gmail (recommended — most reliable, port 587 rarely blocked):
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-16-char-app-password   # Gmail App Password (not your real password)
SMTP_FROM=you@gmail.com
SMTP_TLS=true

# Namecheap cPanel alternative (port 587 only — 465 often ISP-blocked):
# SMTP_HOST=bonhomieinc.dev
# SMTP_PORT=587
# SMTP_USER=you@yourdomain.com
# SMTP_PASSWORD=your-email-password
# SMTP_FROM=you@yourdomain.com
# SMTP_TLS=true

SMTP_AUTO_SEND=true         # Send emails automatically during pipeline run
SMTP_ATTACH_PDF=true
SMTP_ATTACH_DOCX=false
SMTP_RETRY_COUNT=3
SMTP_THROTTLE_SECONDS=8     # Min seconds between sends (raise to 30+ for new domains)
SMTP_FORMAT=plain            # plain (better inbox placement) or mixed (plain+HTML)

# ── Duplicate Guard ───────────────────────────────────────
# Skip sending if the same HR email was contacted within this many days
DEDUP_WINDOW_DAYS=30

# ── Follow-Up Emails ──────────────────────────────────────
FOLLOW_UP_ENABLED=true
FOLLOW_UP_DAYS=6            # Days after initial send before follow-up fires

# ── IMAP (Reply Detection) ────────────────────────────────
# Used to check if a recruiter replied so follow-ups are skipped.
# Defaults to Gmail IMAP — works with any IMAP provider.
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
# IMAP_USER and IMAP_PASSWORD default to SMTP_USER / SMTP_PASSWORD
# Override below only if your IMAP login differs from SMTP:
# IMAP_USER=you@gmail.com
# IMAP_PASSWORD=your-16-char-app-password

# ── App ───────────────────────────────────────────────────
FLASK_PORT=9000
FLASK_DEBUG=false
TIMEZONE=Africa/Lagos

# ── Proxy / SOCKS (optional — improves scraping reliability) ──
# Comma-separated list. Supported formats:
#   socks5://user:pass@host:port
#   socks5://host:port
#   http://user:pass@host:port
# Paid residential proxies (Webshare, Oxylabs) work best for LinkedIn/Indeed.
PROXY_ENABLED=false
# PROXY_LIST=socks5://user:pass@1.2.3.4:1080,socks5://user:pass@5.6.7.8:1080


# ── Ollama Fallback ──────────────────────────────────────────
# Used automatically when ALL Groq keys are rate-limited.
# No code changes needed — drop-in transparent fallback.
# Models are tried in priority order — first available one wins.
# You already have all of these installed locally.
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
# Priority order — best quality first, fastest last
OLLAMA_MODELS=qwen2.5-coder:32b,gemma3:12b,qwen3:6b,mistral


# ── Scheduler (auto-run pipeline) ────────────────────────────
# Runs the full pipeline automatically on a cron schedule.
# Standard 5-field cron: minute hour day month weekday
# Examples:
#   "0 8 * * 1-5"   = Mon-Fri at 08:00
#   "0 9 * * *"     = Every day at 09:00
#   "0 8,17 * * *"  = Twice daily at 08:00 and 17:00
SCHEDULE_ENABLED=false
SCHEDULE_CRON=0 8 * * 1-5
# Also run follow-up cycle after each scheduled pipeline run
SCHEDULE_FOLLOWUP=true


# ── Telegram Notifications ────────────────────────────────────
# Sends a summary message when a run finishes, replies are detected, etc.
# Setup: message @BotFather on Telegram → /newbot → copy token
#        message @userinfobot → copy your chat_id
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_CHAT_ID


# ── CV Version Management ─────────────────────────────────────
# Pin a specific CV file from input/ to use for all runs.
# Leave blank to auto-pick the first file found (original behaviour).
# Can also be changed live from the dashboard without restarting.
# Example: ACTIVE_CV=CV_web3.docx
ACTIVE_CV=


# ── Portal Auto-Fill (Playwright) ────────────────────────────
# Automatically fills and submits job application portals
# for jobs that have an apply URL but no HR email.
# Supports: Greenhouse, Lever, Ashby, Workday, SmartRecruiters,
#           and generic HTML forms (best-effort fallback).
#
# Setup (one-time):
#   pip install playwright
#   playwright install chromium
#
PORTAL_ENABLED=false
# Show browser window while filling (useful for debugging)
PORTAL_HEADLESS=true
# false = fill the form but don't click Submit (dry run to verify)
PORTAL_SUBMIT=true
# Max milliseconds to wait for page elements
PORTAL_TIMEOUT_MS=30000
